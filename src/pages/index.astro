---
const backgrounds = Array.from(
	{ length: 5 },
	(_, index) => `/images/page-bg-${index + 1}.jpg`,
);

const posters = [
	{
		href: "https://youtu.be/OdR8--J-0gk",
		path: "/images/poster-corrupt-dialtone.jpg",
		title: "Corrupt Dialtone",
	},
	{
		href: "https://youtu.be/3KFraihm7dE",
		path: "/images/poster-the-boiled-one.jpg",
		title: "The Boiled One",
	},
	{
		href: "https://youtu.be/ddYEd6HQR3w",
		path: "/images/poster-the-faucet.jpg",
		title: "The Faucet",
	},
];

const tracks = [
	{ href: "https://youtu.be/LQniGgAO20g", title: "Life Sucks" },
	{ href: "https://youtu.be/y6FIuqGSdMA", title: "Corrupt Dialtone" },
	{ href: "https://youtu.be/1ch-rxLTNY0", title: "It Won’t Stop" },
	{ href: "https://youtu.be/nCcA-5osr7o", title: "The Boiled One" },
	{ href: "https://youtu.be/uqpSIdNDnLQ", title: "The Faucet" },
	{ href: "https://youtu.be/4RXsn1XAY7o", title: "Young Man" },
	{ href: "https://youtu.be/vehtzSdEMCQ", title: "Choker" },
	{ href: "https://youtu.be/51cSs7_5JVI", title: "Pro-Death" },
	{ href: "https://youtu.be/6niJRkJr-5o", title: "This Is Rock Bottom" },
	{ href: "https://youtu.be/JvnG2JB3o_o", title: "Warmer" },
];
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta
			name="viewport"
			content="width=device-width, initial-scale=1, viewport-fit=cover"
		/>
		<link rel="stylesheet" href="https://use.typekit.net/sqy0qym.css" />
		<link rel="preload" href="/images/album-art.png" as="image" />
		{backgrounds.map((background, index) => (
			<link
				rel="preload"
				href={background}
				as="image"
				fetchpriority={index === 0 ? "high" : "low"}
			/>
		))}
		{posters.map(({ path }) => (
			<link rel="preload" href={path} as="image" />
		))}
		<title>CRAWLER</title>
	</head>
	<body>
		<div class="background" aria-hidden="true">
			{backgrounds.map((background, index) => (
				<img
					class:list={{ active: index === 0 }}
					src={background}
					alt=""
					decoding={index === 0 ? "sync" : "async"}
					fetchpriority={index === 0 ? "high" : "low"}
				/>
			))}
		</div>
		<main>
			<div class="cover">
				<section class="back" id="back-cover" aria-label="Back cover">
					<section class="track-list" aria-labelledby="track-list-title">
						<h2 id="track-list-title">Track listing</h2>
						<ol class="tracks">
							{tracks.map(({ href, title }, index) => (
								<li>
									<a
										href={href ?? "#"}
										data-placeholder={href ? undefined : true}
										rel="noreferrer"
										target="_blank"
									>
										<span class="track-number">
											{String(index + 1).padStart(2, "0")}
										</span>
										<span>{title}</span>
									</a>
								</li>
							))}
						</ol>
					</section>
					<section class="release" aria-label="Download and listen">
						<p>
							NEEDS HELP - pre-release preview.
						</p>
						<nav aria-label="Album links">
							<a
								class="action"
								href="https://www.dropbox.com/scl/fo/dzemgg5cpm5ml1al1jc03/AA8qZD0Qwolbaeg79mW_lZY?rlkey=4ayj78a4yzw09qet192pl68mt&e=2&st=jeubea2l&dl=0"
								rel="noreferrer"
								target="_blank"
							>
								Dropbox
							</a>
							<a
								class="action"
								href="https://www.youtube.com/playlist?list=PLILVosQN11ds"
								rel="noreferrer"
								target="_blank"
							>
								YouTube
							</a>
						</nav>
					</section>
					<h2 class="videos-title">
						Music videos
					</h2>
					{posters.map(({ href, path, title }, index) => (
						<a
							class={`poster poster-${index + 1}`}
							href={href}
							target="_blank"
							rel="noreferrer"
						>
							<img src={path} alt="" decoding="async" />
							<span>{title}</span>
						</a>
					))}
				</section>
				<button
					class="front"
					type="button"
					aria-controls="back-cover"
					aria-expanded="false"
					aria-label="Toggle back cover"
				>
					<img
						src="/images/album-art.png"
						alt="Needs Help album cover"
						decoding="sync"
						fetchpriority="high"
						height="1024"
						width="1024"
					/>
				</button>
			</div>
		</main>
	</body>
</html>

<style>
	:global(html) {
		background: #ffaeda;
	}

	body {
		background: #ffaeda;
		margin: 0;
	}

	.background {
		background: #ffaeda;
		inset: 0;
		isolation: isolate;
		position: fixed;
	}

	.background img {
		height: 100%;
		inset: 0;
		mix-blend-mode: multiply;
		object-fit: cover;
		object-position: center;
		opacity: 0;
		position: absolute;
		width: 100%;
	}

	.background.ready img {
		transition: opacity 5s linear;
	}

	.background img.active {
		opacity: 1;
	}

	main {
		height: 200svh;
		position: relative;
	}

	.cover {
		--cover-size: min(80vmin, calc(50vw - 2vmin));

		height: 100svh;
		overflow: hidden;
		position: sticky;
		top: 0;
		width: 100%;
	}

	@media (max-width: 48rem) {
		.background {
			height: 200svh;
			inset: 0 0 auto;
			position: absolute;
		}

		.cover {
			inset: 0;
			position: fixed;
		}
	}

	.back,
	.front {
		aspect-ratio: 1;
		height: var(--cover-size);
		left: 50%;
		position: absolute;
		top: 50%;
		width: var(--cover-size);
	}

	.back {
		background: #ffaeda;
		box-sizing: border-box;
		display: grid;
		gap: 1.5vmin;
		grid-template-columns: repeat(6, minmax(0, 1fr));
		grid-template-rows: minmax(0, 1fr) 44%;
		overflow: hidden;
		padding: 4vmin;
		transform: translate(calc(-50% + var(--split, 0px)), -50%);
		z-index: 1;
	}

	.track-list {
		display: grid;
		font-family: "erotique", sans-serif;
		font-style: normal;
		font-weight: 700;
		gap: 0.6vmin;
		grid-column: 1 / 4;
		grid-template-rows: auto minmax(0, 1fr);
		min-height: 0;
	}

	.track-list h2 {
		font-size: clamp(0.55rem, 1.4vmin, 1rem);
		line-height: 1;
		margin: 0;
	}

	.tracks {
		line-height: 1;
		list-style: none;
		margin: 0;
		padding: 0;
		container-type: size;
	}

	.tracks li {
		font-size: min(8.8cqh, 9.5cqw);
	}

	.tracks a {
		color: inherit;
		display: flex;
		gap: 0.55em;
		text-decoration: none;
	}

	.track-number {
		flex: 0 0 2ch;
		font-size: 0.62em;
		font-variant-numeric: tabular-nums;
		opacity: 0.45;
		padding-top: 0.18em;
	}

	.release {
		container-type: size;
		display: flex;
		flex-direction: column;
		font-family: "erotique-alternate", sans-serif;
		font-style: normal;
		font-weight: 700;
		grid-column: 4 / 7;
		grid-row: 1;
		justify-content: center;
		line-height: 1;
		min-width: 0;
	}

	.release p {
		opacity: 0.7;
		font-size: clamp(0.8rem, 1.6vmin, 2rem);
		line-height: 1.05;
		margin: 0;
		text-align: center;
	}

	.release cite {
		font-style: normal;
	}

	.release nav {
		align-items: stretch;
		display: flex;
		flex-direction: column;
		gap: 0.6vmin;
		margin-top: 1.25vmin;
	}

	.action {
		background: #111;
		border: 1px solid currentColor;
		box-sizing: border-box;
		color: #ffaeda;
		font-family: "erotique", sans-serif;
		font-size: clamp(0.8rem, 1.6vmin, 2rem);
		line-height: 1;
		padding: 0.5em;
		text-align: center;
		text-decoration: none;
		width: 100%;
	}

	.poster {
		color: inherit;
		grid-row: 2;
		margin: 0;
		min-width: 0;
		overflow: hidden;
		position: relative;
		text-decoration: none;
		transition: filter 180ms ease-out;
	}

	.videos-title {
		align-self: start;
		background: #ffaeda;
		font-family: "erotique", sans-serif;
		font-size: clamp(0.55rem, 1.4vmin, 1rem);
		font-style: normal;
		font-weight: 700;
		grid-column: 1 / 7;
		grid-row: 2;
		justify-self: start;
		line-height: 1;
		margin: 0.8vmin;
		padding: 0.5em;
		pointer-events: none;
		z-index: 1;
	}

	.poster-1 {
		grid-column: 1 / 3;
	}

	.poster-2 {
		grid-column: 3 / 5;
	}

	.poster-3 {
		grid-column: 5 / 7;
	}

	.poster img {
		mix-blend-mode: multiply;
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.poster span {
		background: #ffaeda;
		bottom: 0;
		box-sizing: border-box;
		font-family: "erotique", sans-serif;
		font-size: clamp(0.4rem, 0.9vmin, 0.7rem);
		font-style: normal;
		font-weight: 700;
		left: 0;
		line-height: 1;
		padding: 0.5em;
		position: absolute;
		width: 100%;
	}

	@media (hover: hover) and (pointer: fine) {
		.background.ready img {
			transition-duration: 120ms;
		}

		.action,
		.tracks a {
			transition:
				background-color 120ms ease-out,
				color 120ms ease-out;
		}

		.tracks a:hover {
			background: #111;
			color: #ffaeda;
		}

		.action:hover {
			background: transparent;
			color: #111;
		}

		.front img {
			transition: filter 180ms ease-out;
		}

		.front:hover img {
			filter: contrast(1.08) brightness(1.08);
		}

		.poster:hover {
			filter: contrast(1.15) brightness(1.1);
		}
	}

	.front {
		background: none;
		border: 0;
		cursor: pointer;
		display: block;
		padding: 0;
		transform: translate(calc(-50% - var(--split, 0px)), -50%);
		z-index: 2;
	}

	.front img {
		display: block;
		height: 100%;
		object-fit: cover;
		width: 100%;
	}

	.front:focus-visible {
		outline: 2px solid currentColor;
		outline-offset: 4px;
	}

	@media (orientation: portrait) {
		.cover {
			--cover-size: min(80vmin, calc(50svh - 2vmin));
		}

		.back {
			transform: translate(-50%, calc(-50% + var(--split, 0px)));
		}

		.front {
			transform: translate(-50%, calc(-50% - var(--split, 0px)));
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.background.ready img {
			transition: none;
		}

		.front img,
		.poster {
			transition: none;
		}
	}
</style>

<script>
	const background = document.querySelector<HTMLElement>(".background");
	const images = document.querySelectorAll<HTMLImageElement>(".background img");
	const cover = document.querySelector<HTMLElement>(".cover");
	const front = document.querySelector<HTMLButtonElement>(".front");
	const main = document.querySelector<HTMLElement>("main");
	const placeholders = document.querySelectorAll<HTMLAnchorElement>("[data-placeholder]");
	const pointer = window.matchMedia("(hover: hover) and (pointer: fine)");
	const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

	let coverRequest = 0;
	let backgroundTimer = 0;
	let frame = 0;
	let lastScroll = window.scrollY;
	let snapDirection = 1;
	let snapTimer = 0;
	let snapping = false;

	function enableBackgroundTransitions() {
		background?.classList.add("ready");
	}

	const firstImage = images.item(0);
	if (firstImage.complete) {
		firstImage.decode().catch(() => {}).finally(enableBackgroundTransitions);
	} else {
		firstImage.addEventListener("load", enableBackgroundTransitions, { once: true });
		firstImage.addEventListener("error", enableBackgroundTransitions, { once: true });
	}

	function show(index: number) {
		frame = index % images.length;
		images.forEach((image, imageIndex) => {
			image.classList.toggle("active", imageIndex === frame);
		});
	}

	function resetBackground() {
		clearInterval(backgroundTimer);

		if (!pointer.matches && !reducedMotion.matches) {
			backgroundTimer = window.setInterval(() => show(frame + 1), 5000);
		}
	}

	window.addEventListener("pointermove", (event) => {
		if (pointer.matches) {
			show(Math.min(Math.floor((event.clientX / window.innerWidth) * images.length), images.length - 1));
		}
	});

	function renderCover() {
		if (!cover || !main) {
			return;
		}

		const range = Math.max(main.offsetHeight - window.innerHeight, 1);
		const progress = Math.min(Math.max(window.scrollY / range, 0), 1);
		const eased = progress < 0.5
			? 4 * Math.pow(progress, 3)
			: 1 - Math.pow(-2 * progress + 2, 3) / 2;
		const size = front?.offsetWidth ?? Math.min(window.innerWidth, window.innerHeight) * 0.8;
		const shift = eased * size / 2;

		cover.style.setProperty("--split", `${shift}px`);
		front?.setAttribute("aria-expanded", String(progress >= 0.5));
	}

	function toggleCover() {
		if (!main) {
			return;
		}

		const range = Math.max(main.offsetHeight - window.innerHeight, 1);
		window.scrollTo({
			behavior: reducedMotion.matches ? "auto" : "smooth",
			top: window.scrollY < range / 2 ? range : 0,
		});
	}

	function queueCover() {
		cancelAnimationFrame(coverRequest);
		coverRequest = requestAnimationFrame(renderCover);

		const delta = window.scrollY - lastScroll;
		if (Math.abs(delta) > 1) {
			snapDirection = Math.sign(delta);
		}
		lastScroll = window.scrollY;

		clearTimeout(snapTimer);
		if (!snapping) {
			snapTimer = window.setTimeout(snapCover, 140);
		}
	}

	function snapCover() {
		if (!main) {
			return;
		}

		const range = Math.max(main.offsetHeight - window.innerHeight, 1);
		if (window.scrollY <= 0 || window.scrollY >= range) {
			return;
		}

		snapping = true;
		window.scrollTo({
			behavior: reducedMotion.matches ? "auto" : "smooth",
			top: snapDirection < 0 ? 0 : range,
		});

		window.setTimeout(() => {
			lastScroll = window.scrollY;
			snapping = false;
		}, reducedMotion.matches ? 0 : 800);
	}

	window.addEventListener("resize", queueCover);
	window.addEventListener("scroll", queueCover, { passive: true });
	front?.addEventListener("click", toggleCover);
	placeholders.forEach((placeholder) => {
		placeholder.addEventListener("click", (event) => event.preventDefault());
	});
	pointer.addEventListener("change", resetBackground);
	reducedMotion.addEventListener("change", resetBackground);
	renderCover();
	resetBackground();
</script>
